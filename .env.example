# Copy this file to .env and replace every example value before deployment.
# Never commit .env.

# Public HTTPS origin of this MCP server, without a trailing slash.
MCP_PUBLIC_ORIGIN=https://mcp.example.com

# Directory containing this connector source code. Mounted as /codebase.
AGENT_CODEBASE=/path/to/chatgpt-cli-agent

# Directory containing repositories/projects the agent may work with. Mounted as /workspace.
AGENT_WORKSPACE_ROOT=/path/to/projects

# Persistent home for notes, screenshots, plans, and agent state. Mounted as /agent-home.
AGENT_HOME=~/.ai-agent

# Auth mode: oauth is recommended for public deployments.
# Other modes: legacy_bearer for private/internal deployments, noauth for local-only development.
AUTH_MODE=oauth

# Legacy Bearer mode only. Generate with: openssl rand -base64 48
# AGENT_AUTH_TOKEN=replace-with-long-random-token

# OAuth / protected-resource metadata.
OAUTH_RESOURCE=${MCP_PUBLIC_ORIGIN}
OAUTH_AUDIENCE=${MCP_PUBLIC_ORIGIN}
OAUTH_REQUIRED_SCOPE=cli:run

# Self-hosted Keycloak provider from docker-compose.yml.
OAUTH_ISSUER=${MCP_PUBLIC_ORIGIN}/auth/realms/gpt-connector
OAUTH_JWKS_URI=${MCP_PUBLIC_ORIGIN}/auth/realms/gpt-connector/protocol/openid-connect/certs
KEYCLOAK_INTERNAL_ORIGIN=http://keycloak:8080/auth

# Keycloak bootstrap values. Generate strong unique passwords before first start.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-strong-admin-password
KEYCLOAK_DB_PASSWORD=replace-with-strong-db-password
KEYCLOAK_CONNECTOR_USER=agent-user
KEYCLOAK_CONNECTOR_USER_EMAIL=agent-user@example.com
KEYCLOAK_CONNECTOR_USER_PASSWORD=replace-with-strong-login-password

# Runtime limits.
COMMAND_TIMEOUT_MS=120000
MAX_OUTPUT_CHARS=200000
MAX_COMMAND_TIMEOUT_MS=300000
LOGS_ROOT=/app/logs

# Optional: internal proxy target when using a reverse proxy on another host.
# Example Nginx Proxy Manager targets:
#   /auth -> http://100.64.0.10:8080
#   /     -> http://100.64.0.10:9999
# TAILSCALE_PROXY_TARGET=100.64.0.10
